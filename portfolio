<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mélanie Dupriez | Portfolio</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;600&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #FFF2F0; color: #2D1D20; }
        h1, h2, h3, h4 { font-family: 'Cormorant Garamond', serif; }
        .glass { background: rgba(255, 255, 255, 0.5); backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.3); }
    </style>
</head>
<body class="py-12">

    <!-- Navigation -->
    <nav class="max-w-5xl mx-auto px-6 flex justify-between items-center mb-20">
        <span class="text-xl font-serif font-bold text-[#7A1C36]">MD.</span>
        <div class="space-x-8 text-sm uppercase tracking-widest text-[#7A1C36]">
            <a href="#projets" class="hover:underline">Projets</a>
            <a href="#certifications" class="hover:underline">Certifications</a>
            <a href="#contact" class="hover:underline">Contact</a>
        </div>
    </nav>

    <!-- Hero -->
    <main class="max-w-4xl mx-auto px-6 text-center mb-32">
        <h2 class="text-sm uppercase tracking-widest text-[#7A1C36] mb-4">Business Data Analyst</h2>
        <h1 class="text-7xl mb-8">Mélanie Dupriez.</h1>
        <p class="text-lg leading-relaxed text-[#5C4B4E] max-w-2xl mx-auto">
            Étudiante en ingénieur de gestion, je transforme des données complexes en récits visuels clairs. Mon passé de photographe guide ma rigueur analytique.
        </p>
    </main>

    <!-- Projets -->
    <section id="projets" class="max-w-5xl mx-auto px-6 mb-32">
        <h3 class="text-4xl text-[#7A1C36] mb-12 text-center">Mes Projets</h3>
        <div class="grid md:grid-cols-2 gap-8">
            <div class="glass p-8 rounded-[30px] shadow-sm hover:shadow-xl transition duration-500">
                <h4 class="text-2xl mb-2">Analyse Économique</h4>
                <p class="text-sm text-[#5C4B4E] mb-6">Utilisation de Python et SQL pour identifier des tendances macro-économiques.</p>
                <div class="flex gap-2 mb-6">
                    <span class="px-3 py-1 bg-[#F3ECE9] rounded-full text-[10px] uppercase font-bold text-[#7A1C36]">Python</span>
                    <span class="px-3 py-1 bg-[#F3ECE9] rounded-full text-[10px] uppercase font-bold text-[#7A1C36]">SQL</span>
                </div>
                <a href="#" class="text-[#7A1C36] font-bold border-b border-[#7A1C36]">Voir le projet →</a>
            </div>
            <div class="glass p-8 rounded-[30px] shadow-sm hover:shadow-xl transition duration-500">
                <h4 class="text-2xl mb-2">Dashboard Ventes</h4>
                <p class="text-sm text-[#5C4B4E] mb-6">Visualisation interactive sous Power BI pour optimiser le pilotage commercial.</p>
                <div class="flex gap-2 mb-6">
                    <span class="px-3 py-1 bg-[#F3ECE9] rounded-full text-[10px] uppercase font-bold text-[#7A1C36]">Power BI</span>
                    <span class="px-3 py-1 bg-[#F3ECE9] rounded-full text-[10px] uppercase font-bold text-[#7A1C36]">DAX</span>
                </div>
                <a href="#" class="text-[#7A1C36] font-bold border-b border-[#7A1C36]">Voir le projet →</a>
            </div>
        </div>
    </section>

    <!-- Certifications -->
    <section id="certifications" class="max-w-4xl mx-auto px-6 mb-32 text-center">
        <h3 class="text-3xl text-[#7A1C36] mb-8">Certifications</h3>
        <div class="flex flex-wrap justify-center gap-4">
            <span class="glass px-6 py-3 rounded-full text-sm font-medium">Google Data Analytics</span>
            <span class="glass px-6 py-3 rounded-full text-sm font-medium">IBM Data Science</span>
            <span class="glass px-6 py-3 rounded-full text-sm font-medium">Tableau Desktop</span>
        </div>
    </section>

    <!-- Contact -->
    <footer id="contact" class="max-w-4xl mx-auto px-6 py-20 text-center">
        <h3 class="text-3xl mb-8">Travaillons ensemble.</h3>
        <a href="URL_DE_VOTRE_CV.pdf" target="_blank" class="bg-[#7A1C36] text-white px-10 py-4 rounded-full hover:bg-opacity-90 transition shadow-lg">Télécharger mon CV</a>
    </footer>

</body>
</html>
